rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // activity_logs — tulis hanya via Cloud Functions (Admin SDK)
    match /activity_logs/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // daily_logs — tulis hanya via Cloud Functions (Admin SDK)
    match /daily_logs/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // monthly_logs — tulis hanya via Cloud Functions (Admin SDK)
    match /monthly_logs/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // fcm_tokens — diperbolehkan tulis oleh client untuk pendaftaran push notifications
    match /fcm_tokens/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Blokir semua collection lain yang tidak terdaftar
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
