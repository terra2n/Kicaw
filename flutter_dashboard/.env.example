# .env.example
# Copy file ini menjadi .env dan isi dengan credentials asli
# File .env sudah di-gitignore — JANGAN commit ke git
#
# Cara mendapatkan credentials:
#   SUPABASE_URL & SUPABASE_ANON_KEY → Supabase Dashboard → Project Settings → API
#   FIREBASE_API_KEY                 → Firebase Console → Project Settings → General
#   FIREBASE_DATABASE_URL            → Firebase Console → Realtime Database → Data

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_DATABASE_URL=https://your-project-rtdb.firebaseio.com
